# EditorConfig - 跨编辑器统一编码风格
# https://editorconfig.org/
# 安装：VSCode 搜索 "EditorConfig" 扩展并安装

# 根 EditorConfig（向上查找停止于此文件）
root = true

# 默认（所有文件）
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

# Rust 源文件
[*.rs]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
max_line_length = 100
trim_trailing_whitespace = true
insert_final_newline = true

# Cargo 配置
[*.toml]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown
[*.md]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = false  # Markdown 用两个空格表示换行
insert_final_newline = true

# YAML（CI/CD 配置）
[*.{yml,yaml}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = true
insert_final_newline = true

# Shell 脚本
[*.sh]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
max_line_length = 100
trim_trailing_whitespace = true
insert_final_newline = true

# Makefile（必须用 tab）
[Makefile]
charset = utf-8
end_of_line = lf
indent_style = tab
trim_trailing_whitespace = true
insert_final_newline = true

# Dockerfile
[Dockerfile*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# JSON
[*.json]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
